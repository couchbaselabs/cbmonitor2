# Grafana Configuration
GRAFANA_IMAGE=grafana-enterprise
GRAFANA_VERSION=12.4.2
development=true
ANONYMOUS_AUTH_ENABLED=true

# Couchbase credentials consumed by:
#   - provisioning/datasources/datasource.yaml (couchbase-datasource plugin)
#   - provisioning/plugins/apps.yaml

COUCHBASE_CONNECTION_STRING=couchbase://localhost
COUCHBASE_USERNAME=Administrator
COUCHBASE_PASSWORD=password
COUCHBASE_BUCKET=showfast
COUCHBASE_SNAPSHOT_BUCKET=metadata

# cbmonitor feature toggles
CBMONITOR_SNAPSHOTS_ENABLED=true
CBMONITOR_COUCHBASE_DS_ENABLED=false
CBMONITOR_PROMETHEUS_DS_ENABLED=true
CBMONITOR_PROMETHEUS_DS_IS_DEFAULT=true

# Plugin Configuration
GF_LOG_FILTERS=plugin.cbmonitor:info
GF_LOG_LEVEL=info
GF_DATAPROXY_LOGGING=1
GF_PLUGINS_ALLOW_LOADING_UNSIGNED_PLUGINS=cbmonitor, couchbase-datasource
GF_PLUGIN_APP_TLS_SKIP_VERIFY_INSECURE=true

#Prometheus Configuration
PROMETHEUS_URL=http://localhost:9090/
