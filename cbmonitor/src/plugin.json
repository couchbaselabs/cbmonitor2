{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "cbmonitor",
  "id": "cbmonitor",
  "backend": true,
  "executable": "cbmonitor",
  "preload": true,
  "info": {
    "keywords": ["app"],
    "description": "",
    "author": {
      "name": "Couchbase"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Metrics",
      "path": "/a/%PLUGIN_ID%/snapshots",
      "addToNav": true,
      "defaultNav": true,
      "icon": "home-alt"
    },
    {
      "type": "page",
      "name": "Compare",
      "path": "/a/%PLUGIN_ID%/compare",
      "addToNav": true,
      "defaultNav": false,
      "icon": "home-alt"
    },
    {
      "type": "page",
      "name": "User Preferences",
      "path": "/a/%PLUGIN_ID%/preferences",
      "role": "Viewer",
      "addToNav": true,
      "defaultNav": false,
      "icon": "sliders-v-alt"
    },
    {
      "type": "page",
      "icon": "cog",
      "name": "Configuration",
      "path": "/plugins/%PLUGIN_ID%",
      "role": "Admin",
      "addToNav": true
    }
  ],
  "iam": {
    "permissions": [
      { "action": "datasources:read",   "scope": "datasources:uid:prometheus" },
      { "action": "datasources:read",   "scope": "datasources:uid:cbdatasource" },
      { "action": "datasources:create" },
      { "action": "datasources:write",  "scope": "datasources:uid:prometheus" },
      { "action": "datasources:write",  "scope": "datasources:uid:cbdatasource" },
      { "action": "datasources:delete", "scope": "datasources:uid:prometheus" },
      { "action": "datasources:delete", "scope": "datasources:uid:cbdatasource" },

      { "action": "folders:read",      "scope": "folders:uid:*" },
      { "action": "folders:write",     "scope": "folders:uid:*" },
      { "action": "folders:create" },
      { "action": "dashboards:read",   "scope": "folders:uid:*" },
      { "action": "dashboards:read",   "scope": "dashboards:uid:*" },
      { "action": "dashboards:create", "scope": "folders:uid:*" },
      { "action": "dashboards:write",  "scope": "folders:uid:*" },
      { "action": "dashboards:write",  "scope": "dashboards:uid:*" },

      { "action": "annotations:read",   "scope": "annotations:type:organization" },
      { "action": "annotations:create", "scope": "annotations:type:organization" },
      { "action": "annotations:delete", "scope": "annotations:type:organization" }
    ]
  },
  "dependencies": {
    "grafanaDependency": ">=11.6.0",
    "plugins": []
  }
}
